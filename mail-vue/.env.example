# Required for the server-authoritative Desktop acceptance flow.
# Values must match an entry in the Worker's NEXORA_ACCEPTANCE_BUILDS_JSON allowlist.
# Never hardcode production values in source control.
VITE_NEXORA_BUILD_ID=
VITE_NEXORA_BUILD_VERSION=
# Full reviewed source commit embedded into the immutable release bundle.
VITE_NEXORA_SOURCE_COMMIT=
# Version of the reviewed server-side build allowlist policy.
VITE_NEXORA_BUILD_POLICY_VERSION=
